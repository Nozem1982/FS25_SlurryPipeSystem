<!-- Author: Oscar Mods -->
<!-- Version: 1.0.0.0 -->

<slurryPipeSystem>
    <nodeTree filename="nodeTree.i3d"/>
	
	<pump pumpType="HVP"/>     <!-- vacuum/HVP/conduit/openTop -->
	
    <!-- Spreader blockage nodes.
         Order here is the node INDEX used for multiplayer sync, so keep it stable.
         A node whose name contains "Macerator" is the central distributor (tier 1):
         blocking it stops the whole bar. All other nodes are independent outlets
         (tier 2): each blocked outlet only stops its own section.
         The macerator and the centre outlet share a physical spot, so they are never
         both flagged.

         blockageAnimation is OPTIONAL per node:
           - present -> that animation plays on block (forward) and clear (reverse)
           - absent  -> no animation is played for that node (skipped). -->
    <blockageNodes>
        <blockageNode mountNodeName="SPS_blockageNodeMacerator01" blockageAnimation="blockMacerator01"/>
		<blockageNode mountNodeName="SPS_blockageNodeMacerator02" blockageAnimation="blockMacerator02"/>
		<blockageNode mountNodeName="SPS_blockageNodeMacerator03" blockageAnimation="blockMacerator03"/>
		<blockageNode mountNodeName="SPS_blockageNodeMacerator04" blockageAnimation="blockMacerator04"/>
		
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry01" workAreaNode="workArea01"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry02" workAreaNode="workArea02"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry03" workAreaNode="workArea03"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry04" workAreaNode="workArea04"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry05" workAreaNode="workArea05"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry06" workAreaNode="workArea06"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry07" workAreaNode="workArea07"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry08" workAreaNode="workArea08"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurry09" workAreaNode="workArea09"/>
    </blockageNodes>

</slurryPipeSystem>