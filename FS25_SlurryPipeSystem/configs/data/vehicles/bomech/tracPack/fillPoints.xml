<slurryPipeSystem>
    <nodeTree filename="nodeTree.i3d"/>
	
	<pump pumpType="HVP"/>     <!-- vacuum/HVP/conduit/openTop -->
	
    <!-- Spreader blockage nodes.
         Order here is the node INDEX used for multiplayer sync, so keep it stable.
         A node whose name contains "Macerator" is the central distributor (tier 1):
         blocking it stops the whole bar. All other nodes are independent outlets
         (tier 2): each blocked outlet only stops its own section.
         The macerator and the centre outlet share a physical spot, so they are never
         both flagged.

         blockageAnimation is OPTIONAL per node:
           - present -> that animation plays on block (forward) and clear (reverse)
           - absent  -> no animation is played for that node (skipped). -->
    <blockageNodes>
        <blockageNode mountNodeName="SPS_blockageNodeMacerator01" blockageAnimation="blockMacerator01"/>
		<blockageNode mountNodeName="SPS_blockageNodeMacerator02" blockageAnimation="blockMacerator02"/>
		
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmLeft04" workAreaNode="workArea01"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmLeft03" workAreaNode="workArea02"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmLeft02" workAreaNode="workArea03"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmLeft01" workAreaNode="workArea04"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmMiddle" workAreaNode="workArea05"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmRight01" workAreaNode="workArea06"/>
        <blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmRight02" workAreaNode="workArea07"/>
		<blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmRight03" workAreaNode="workArea08"/>
		<blockageNode mountNodeName="SPS_blockageNodeEffectSlurryArmRight04" workAreaNode="workArea09"/>
    </blockageNodes>

</slurryPipeSystem>