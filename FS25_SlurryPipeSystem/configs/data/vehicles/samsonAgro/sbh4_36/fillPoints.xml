<slurryPipeSystem>
    <nodeTree filename="nodeTree.i3d"/>
	
	<pump pumpType="HVP"/>     <!-- vacuum/HVP/conduit/openTop -->
	
    <!-- Spreader blockage nodes.
         Order here is the node INDEX used for multiplayer sync, so keep it stable.
         A node whose name contains "Macerator" is the central distributor (tier 1):
         blocking it stops the whole bar. All other nodes are independent outlets
         (tier 2): each blocked outlet only stops its own section.
         The macerator and the centre outlet share a physical spot, so they are never
         both flagged.

         blockageAnimation is OPTIONAL per node:
           - present -> that animation plays on block (forward) and clear (reverse)
           - absent  -> no animation is played for that node (skipped). -->
    <blockageNodes>
        <blockageNode mountNodeName="SPS_blockageNodeMacerator" blockageAnimation="blockMacerator"/>
        
		<blockageNode mountNodeName="SPS_blockageNodeCentre01" workAreaNode="workAreaCenter"/>
        <blockageNode mountNodeName="SPS_blockageNodeLeft01" workAreaNode="workAreaLeft01"/>
        <blockageNode mountNodeName="SPS_blockageNodeLeft02" workAreaNode="workAreaLeft02"/>
        <blockageNode mountNodeName="SPS_blockageNodeLeft03" workAreaNode="workAreaLeft03"/>
        <blockageNode mountNodeName="SPS_blockageNodeLeft04" workAreaNode="workAreaLeft04"/>
        <blockageNode mountNodeName="SPS_blockageNodeRight01" workAreaNode="workAreaRight01"/>
        <blockageNode mountNodeName="SPS_blockageNodeRight02" workAreaNode="workAreaRight02"/>
        <blockageNode mountNodeName="SPS_blockageNodeRight03" workAreaNode="workAreaRight03"/>
        <blockageNode mountNodeName="SPS_blockageNodeRight04" workAreaNode="workAreaRight04"/>
    </blockageNodes>

</slurryPipeSystem>