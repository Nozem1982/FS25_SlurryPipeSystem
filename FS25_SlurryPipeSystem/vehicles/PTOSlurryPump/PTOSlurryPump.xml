<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="manurePump" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>PTO Slurry pmp</name>
        <specs>
            <neededPower>120</neededPower>
        </specs>
        <functions>
            <function>$l10n_function_slurryPump</function>
        </functions>
        <image>vehicles/PTOSlurryPump/store_pump.png</image>
        <price>1200</price>
        <lifetime>600</lifetime>
        <rotation>0</rotation>
        <brand>SPS</brand>
        <category>slurryTanks</category>
        <shopTranslationOffset>0 0 0</shopTranslationOffset>
        <shopRotationOffset>0 0 0</shopRotationOffset>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_manurePump</typeDesc>
        <filename>vehicles/PTOSlurryPump/PTOSlurryPump.i3d</filename>
        <size width="1" length="1" height="1"/>
		<components>
			<component centerOfMass="0 0.5 0" mass="150"/>
		</components>
        <schemaOverlay attacherJointPosition="0 0" name="IMPLEMENT"/>
        <mapHotspot type="TOOL" />
    </base>

    <attachable>
        <inputAttacherJoints>
            <inputAttacherJoint node="attacherJoint" jointType="implement" topReferenceNode="topReferenceNode" upperRotationOffset="3" lowerRotLimitScale="0 0 0">
                <distanceToGround lower="-0.2" upper="1.0"/>
                <bottomArm categories="2" ballType="1"/>
            </inputAttacherJoint>
        </inputAttacherJoints>
    </attachable>
	
	<wheels>
	</wheels>
	
    <powerTakeOffs>
        <input inputAttacherJointIndices="1" inputNode="PTOInputNode" aboveAttacher="true" materialTemplateName="SHARED_BLACK1" decalMaterialTemplateName="WALTERSCHEID_YELLOW1"/>
        <sounds>
            <turnedOn template="tractorPTO" volumeScale="0.6" />
        </sounds>
    </powerTakeOffs>

    <connectionHoses>
        <hose inputAttacherJointIndices="1" type="hydraulicIn"  node="hydraulicIn01" adapterNode="hydraulicIn01_detached" length="0.8" diameter="0.016" straighteningFactor="0.5" minCenterPointOffset="-0.15 0 0" maxCenterPointOffset="-0.15 0 0">
           <objectChange node="hydraulicIn01_detached" visibilityActive="false" visibilityInactive="true"/>
        </hose>
    </connectionHoses>

    <powerConsumer ptoRpm="470" neededMinPtoPower="60" neededMaxPtoPower="100"/>

    <turnOnVehicle turnOffIfNotAllowed="true">
        <sounds>
            <start template="mowerToolStart_01" linkNode="PTOSlurryPump_vis" />
            <stop template="mowerToolStop_01"   linkNode="PTOSlurryPump_vis" />
            <work template="mowerToolLoop_01"   linkNode="PTOSlurryPump_vis" />
        </sounds>
    </turnOnVehicle>

    <ai>
        <collisionTrigger useSize="true"/>
        <needsLowering value="true"/>
        <agentAttachment useSize="true"/>
    </ai>

    <foliageBending>
        <bendingNode minX="-2.15" maxX="1.25" minZ="-0.8" maxZ="0.8" yOffset="-0.5"/>
    </foliageBending>
	
	<wearable wearDuration="480" workMultiplier="5" fieldMultiplier="2"/>
    <washable dirtDuration="90" washDuration="1" workMultiplier="4" fieldMultiplier="2"/>
	
	<slurryPipeSystem>
		<flow litersPerSecond="1000"/>
		<pump selfPowered="false" pumpType="conduit"/>
		<pipeCouplings>
			<pipeCoupling id="1" mountNodeName="SPS_pipeCoupler01" valveType="HYDRAULIC" maxPipeLength="4.0" connector="male"/>
			<pipeCoupling id="2" mountNodeName="SPS_pipeCoupler02" valveType="HYDRAULIC" maxPipeLength="4.0" connector="male"/>
		</pipeCouplings>
	</slurryPipeSystem>

    <i3dMappings>
        <i3dMapping id="PTOSlurryPump_main_component1" node="0>"/>
		<i3dMapping id="PTOSlurryPump_vis" node="0>0"/>
		<i3dMapping id="attachable" node="0>0|0"/>
		<i3dMapping id="attacherJointImplement" node="0>0|0|0"/>
		<i3dMapping id="attacherJoint" node="0>0|0|0|0"/>
		<i3dMapping id="topReferenceNode" node="0>0|0|0|1"/>
		<i3dMapping id="PTOInputNode" node="0>0|0|0|2"/>
		<i3dMapping id="connectionHoses" node="0>0|0|1"/>
		<i3dMapping id="connectorFitting" node="0>0|0|1|0"/>
		<i3dMapping id="hydraulicIn01" node="0>0|0|1|1"/>
		<i3dMapping id="hydraulicIn01_detached" node="0>0|0|1|2"/>
		<i3dMapping id="linkBalls" node="0>0|0|2"/>
		<i3dMapping id="linkBallNode01" node="0>0|0|2|0"/>
		<i3dMapping id="linkBallNode02" node="0>0|0|2|1"/>
		<i3dMapping id="linkBallNode03" node="0>0|0|2|2"/>
		<i3dMapping id="linkBallNode04" node="0>0|0|2|3"/>
		<i3dMapping id="linkBallNode05" node="0>0|0|2|4"/>
		<i3dMapping id="SPS_PTOSlurryPump" node="0>0|1"/>
		<i3dMapping id="pipeCouplers" node="0>0|1|0"/>
		<i3dMapping id="PTOSlurryPump_vis1" node="0>0|1|0|0"/>
		<i3dMapping id="SPS_pipeCoupler01" node="0>0|1|0|0|0"/>
		<i3dMapping id="SPS_pipeCoupler01Arcs" node="0>0|1|0|0|0|0"/>
		<i3dMapping id="SPS_pipeCoupler01Arc01" node="0>0|1|0|0|0|0|0"/>
		<i3dMapping id="SPS_pipeCoupler01Arc02" node="0>0|1|0|0|0|0|1"/>
		<i3dMapping id="SPS_pipeCoupler02" node="0>0|1|0|0|1"/>
		<i3dMapping id="SPS_pipeCoupler02Arcs" node="0>0|1|0|0|1|0"/>
		<i3dMapping id="SPS_pipeCoupler02Arc01" node="0>0|1|0|0|1|0|0"/>
		<i3dMapping id="SPS_pipeCoupler02Arc02" node="0>0|1|0|0|1|0|1"/>
    </i3dMappings>
</vehicle>